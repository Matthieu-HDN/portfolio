<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Studio MH{% endblock %} | Studio MH</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/app.css">
</head>
<body class="text-gray-100 {% block body_class %}{% endblock %}" style="background-color: oklch(0.13 0.028 261.692); min-height: 100vh; display: flex; flex-direction: column;">

    <!-- Loader -->
    <div id="page-loader" class="fixed inset-0 z-50 flex items-center justify-center transition-opacity duration-400" style="background-color: oklch(0.13 0.028 261.692);">
        <div class="flex flex-col items-center gap-4">
            <svg class="w-12 h-12 animate-spin text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span class="text-blue-400 text-sm tracking-widest uppercase">Chargement</span>
        </div>
    </div>

    <!-- Overlay transition -->
    <div id="page-transition" class="fixed inset-0 z-40" style="background-color: oklch(0.11 0.02 260.07);"></div>
    <nav class="fixed top-0 w-full bg-gray-900 border-b border-gray-800 z-50">
        <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
            
            <a href="{{ path('app_home') }}">
                <img src="/uploads/media/logo-studio-mh.png" alt="Studio MH" class="h-8">
            </a>

            <!-- Menu desktop -->
            <ul class="hidden md:flex gap-6 text-sm text-gray-400">
                <li><a href="{{ path('app_projects') }}" class="hover:text-white transition">Projets</a></li>
                <li><a href="{{ path('app_skills') }}" class="hover:text-white transition">Compétences</a></li>
                <li><a href="{{ path('app_contact') }}" class="hover:text-white transition">Contact</a></li>
                {% if is_granted('ROLE_ADMIN') %}
                <li><a href="{{ path('app_dashboard') }}" class="text-blue-400 hover:text-blue-300 transition">Admin</a></li>
                <li><a href="{{ path('app_logout') }}" class="text-red-400 hover:text-red-300 transition">Déconnexion</a></li>
                {% endif %}
            </ul>

            <!-- Burger mobile -->
            <button id="burger" class="md:hidden text-gray-400 hover:text-white transition">
                <svg id="burger-icon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
                <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>

        </div>

        <!-- Menu mobile -->
        <div id="mobile-menu" class="md:hidden bg-gray-900 border-t border-gray-800 px-6 py-4">
            <ul class="flex flex-col gap-4 text-sm text-gray-400">
                <li><a href="{{ path('app_projects') }}" class="hover:text-white transition block">Projets</a></li>
                <li><a href="{{ path('app_skills') }}" class="hover:text-white transition block">Compétences</a></li>
                <li><a href="{{ path('app_contact') }}" class="hover:text-white transition block">Contact</a></li>
                {% if is_granted('ROLE_ADMIN') %}
                <li><a href="{{ path('app_dashboard') }}" class="text-blue-400 hover:text-blue-300 transition block">Admin</a></li>
                <li><a href="{{ path('app_logout') }}" class="text-red-400 hover:text-red-300 transition block">Déconnexion</a></li>
                {% endif %}
            </ul>
        </div>
    </nav>

    <script>
        document.getElementById('burger').addEventListener('click', function() {
            const menu = document.getElementById('mobile-menu');
            const burgerIcon = document.getElementById('burger-icon');
            const closeIcon = document.getElementById('close-icon');
            menu.classList.toggle('open');
            burgerIcon.classList.toggle('hidden');
            closeIcon.classList.toggle('hidden');
        });
    </script>

    <main class="pt-16" style="flex: 1;">
        {% block body %}{% endblock %}
    </main>

   <footer class="w-full mt-16" style="background-color: oklch(0.11 0.02 260.07); padding-top: 1.2rem; padding-bottom: 1.2rem;">
        <div class="max-w-5xl mx-auto px-6 py-4">

            <div class="flex justify-between items-start">
                <a href="{{ path('app_home') }}" class="flex items-center">
                    <img src="{{ asset('uploads/media/logo-studio-mh.png') }}" alt="Studio MH" class="h-7 w-auto">
                </a>
                <div class="text-right">
                    <ul class="flex gap-6 text-xs text-gray-500 mb-2">
                        <li><a href="{{ path('app_mentions') }}" class="hover:text-blue-400 transition">Mentions légales</a></li>
                        <li><a href="{{ path('app_cgv') }}" class="hover:text-blue-400 transition">Conditions générales</a></li>
                        <li><a href="{{ path('app_rgpd') }}" class="hover:text-blue-400 transition">RGPD</a></li>
                    </ul>
                    <p class="text-gray-700 text-xs">© {{ "now"|date("Y") }} Studio MH. Tous droits réservés.</p>
                </div>
            </div>

        </div>
    </footer>
    <script src="/js/transitions.js"></script>
</body>
</html>