<form method="post" action="{{ path('app_project_crud_delete', {'id': project.id}) }}" onsubmit="return confirm('Supprimer ce projet ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ project.id) }}">
    <button class="border border-red-800 hover:border-red-600 text-red-400 hover:text-red-300 px-4 py-2 rounded-lg text-sm transition">
        Supprimer ce projet
    </button>
</form>
