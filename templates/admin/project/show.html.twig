{% extends 'base.html.twig' %}

{% block title %}Project{% endblock %}

{% block body %}
    <h1>Project</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ project.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ project.title }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ project.description }}</td>
            </tr>
            <tr>
                <th>Tags</th>
                <td>{{ project.tags }}</td>
            </tr>
            <tr>
                <th>ImageUrl</th>
                <td>{{ project.imageUrl }}</td>
            </tr>
            <tr>
                <th>ProjectUrl</th>
                <td>{{ project.projectUrl }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ project.createdAt ? project.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_project_crud_index') }}">back to list</a>

    <a href="{{ path('app_project_crud_edit', {'id': project.id}) }}">edit</a>

    {{ include('project_crud/_delete_form.html.twig') }}
{% endblock %}
