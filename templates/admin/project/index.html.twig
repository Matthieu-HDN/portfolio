{% extends 'base.html.twig' %}

{% block title %}Projets — Admin{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-6 py-16">

    <div class="flex justify-between items-center mb-2">
        <div>
            <p class="text-blue-400 text-sm uppercase tracking-widest mb-1">Administration</p>
            <h1 class="text-4xl font-bold text-white">Projets</h1>
        </div>
        <div class="flex gap-3">
            <a href="{{ path('app_dashboard') }}" 
               class="border border-gray-700 hover:border-gray-500 text-gray-400 hover:text-white px-4 py-2 rounded-lg text-sm transition">
                ← Dashboard
            </a>
            <a href="{{ path('app_project_crud_new') }}" 
               class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm transition">
                + Nouveau projet
            </a>
        </div>
    </div>

    <p class="text-gray-600 text-sm mb-10">{{ projects|length }} projet{{ projects|length > 1 ? 's' : '' }}</p>

    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-800 text-gray-500 uppercase text-xs tracking-widest">
                    <th class="px-4 py-3 text-left">Image</th>
                    <th class="px-4 py-3 text-left">Titre</th>
                    <th class="px-4 py-3 text-left">Tags</th>
                    <th class="px-4 py-3 text-left">Date</th>
                    <th class="px-4 py-3 text-left">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for project in projects %}
                <tr class="border-b border-gray-800 hover:bg-gray-800 transition">
                    <td class="px-4 py-3">
                        <img src="{{ project.imageUrl ?? 'https://picsum.photos/80/50' }}" 
                             alt="{{ project.title }}"
                             class="w-20 h-12 object-cover rounded-lg">
                    </td>
                    <td class="px-4 py-3">
                        <p class="text-white font-medium">{{ project.title }}</p>
                        <p class="text-gray-500 text-xs mt-1 truncate max-w-xs">{{ project.description }}</p>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex flex-wrap gap-1">
                            {% for tag in project.tags|split(',') %}
                            <span class="text-xs bg-blue-900 text-blue-300 px-2 py-0.5 rounded">{{ tag|trim }}</span>
                            {% endfor %}
                        </div>
                    </td>
                    <td class="px-4 py-3 text-gray-500 text-xs">
                        {{ project.createdAt ? project.createdAt|date('d/m/Y') : '' }}
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex gap-3">
                            <a href="{{ path('app_project_crud_edit', {'id': project.id}) }}" 
                               class="text-blue-400 hover:text-blue-300 transition text-xs">Éditer</a>
                            <a href="{{ path('app_project_crud_show', {'id': project.id}) }}"
                               class="text-gray-400 hover:text-white transition text-xs">Voir</a>
                            <a href="{{ path('app_project_crud_delete', {'id': project.id}) }}"
                               onclick="return confirm('Supprimer ce projet ?')"
                               class="text-red-400 hover:text-red-300 transition text-xs">Supprimer</a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="px-4 py-8 text-center text-gray-600">Aucun projet.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}