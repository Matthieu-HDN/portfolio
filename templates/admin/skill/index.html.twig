{% extends 'base.html.twig' %}

{% block title %}Compétences — Admin{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-6 py-16">

    <div class="flex justify-between items-center mb-2">
        <div>
            <p class="text-blue-400 text-sm uppercase tracking-widest mb-1">Administration</p>
            <h1 class="text-4xl font-bold text-white">Compétences</h1>
        </div>
        <div class="flex gap-3">
            <a href="{{ path('app_dashboard') }}" 
               class="border border-gray-700 hover:border-gray-500 text-gray-400 hover:text-white px-4 py-2 rounded-lg text-sm transition">
                ← Dashboard
            </a>
            <a href="{{ path('app_skill_new') }}" 
               class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm transition">
                + Nouvelle compétence
            </a>
        </div>
    </div>

    <p class="text-gray-600 text-sm mb-10">{{ skills|length }} compétence{{ skills|length > 1 ? 's' : '' }}</p>

    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-800 text-gray-500 uppercase text-xs tracking-widest">
                    <th class="px-4 py-3 text-left">Nom</th>
                    <th class="px-4 py-3 text-left">Catégorie</th>
                    <th class="px-4 py-3 text-left">Niveau</th>
                    <th class="px-4 py-3 text-left">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for skill in skills %}
                <tr class="border-b border-gray-800 hover:bg-gray-800 transition">
                    <td class="px-4 py-3 text-white font-medium">{{ skill.name }}</td>
                    <td class="px-4 py-3 text-gray-400">{{ skill.category }}</td>
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-3">
                            <div class="w-24 bg-gray-800 rounded-full h-1.5">
                                <div class="bg-blue-500 h-1.5 rounded-full" style="width: {{ skill.level }}%"></div>
                            </div>
                            <span class="text-gray-500 text-xs">{{ skill.level }}%</span>
                        </div>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex gap-3 items-center">
                            <a href="{{ path('app_skill_edit', {'id': skill.id}) }}" 
                            title="Éditer"
                            class="text-blue-400 hover:text-blue-300 transition">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </a>
                            <a href="{{ path('app_skill_show', {'id': skill.id}) }}"
                            title="Voir"
                            class="text-gray-400 hover:text-white transition">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.957 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </a>
                            <form method="post" action="{{ path('app_skill_delete', {'id': skill.id}) }}"
                                onsubmit="return confirm('Supprimer cette compétence ?')" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ skill.id) }}">
                                <button type="submit" title="Supprimer" class="text-red-400 hover:text-red-300 transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="px-4 py-8 text-center text-gray-600">Aucune compétence.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}