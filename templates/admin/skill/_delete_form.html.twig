<form method="post" action="{{ path('app_skill_delete', {'id': skill.id}) }}" onsubmit="return confirm('Supprimer cette compétence ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ skill.id) }}">
    <button class="border border-red-800 hover:border-red-600 text-red-400 hover:text-red-300 px-4 py-2 rounded-lg text-sm transition">
        Supprimer cette compétence
    </button>
</form>