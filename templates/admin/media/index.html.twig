{% extends 'base.html.twig' %}

{% block title %}Banque de médias{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-6 py-16">

    <div class="flex justify-between items-center mb-10">
        <div>
            <p class="text-blue-400 text-sm uppercase tracking-widest mb-1">Administration</p>
            <h1 class="text-4xl font-bold text-white">Banque de médias</h1>
        </div>
        <a href="{{ path('app_dashboard') }}"
           class="border border-gray-700 hover:border-gray-500 text-gray-400 hover:text-white px-4 py-2 rounded-lg text-sm transition">
            ← Dashboard
        </a>
    </div>

    {% for message in app.flashes('success') %}
    <div class="bg-blue-900 border border-blue-500 text-blue-300 rounded-lg px-4 py-3 mb-6">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
    <div class="bg-red-900 border border-red-500 text-red-300 rounded-lg px-4 py-3 mb-6">{{ message }}</div>
    {% endfor %}

    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-10">
        <h2 class="text-white font-medium mb-4">Uploader une image</h2>
        <form method="post" action="{{ path('app_media_upload') }}" enctype="multipart/form-data">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="md:col-span-2">
                    <label class="block text-gray-400 text-sm mb-2">Fichier image</label>
                    <input type="file" name="media_file" accept="image/*"
                           class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white text-sm">
                </div>
                <div>
                    <label class="block text-gray-400 text-sm mb-2">Texte alternatif (alt)</label>
                    <input type="text" name="alt" placeholder="Description de l'image"
                           class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition text-sm">
                </div>
            </div>
            <button type="submit"
                    class="mt-4 bg-blue-600 hover:bg-blue-500 text-white px-6 py-2 rounded-lg text-sm transition">
                Uploader
            </button>
        </form>
    </div>

    <p class="text-gray-600 text-sm mb-6">{{ medias|length }} image{{ medias|length > 1 ? 's' : '' }}</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {% for media in medias %}
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden group">
            <div class="h-36 overflow-hidden">
                <img src="/uploads/media/{{ media.filename }}"
                     alt="{{ media.alt }}"
                     class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
            </div>
            <div class="p-3">
                <p class="text-gray-400 text-xs truncate mb-1">{{ media.originalName }}</p>
                <p class="text-gray-600 text-xs mb-3">{{ media.alt ?: 'Sans alt' }}</p>
                <div class="flex justify-between items-center">
                    <button onclick="copyUrl('/uploads/media/{{ media.filename }}')"
                            class="text-blue-400 hover:text-blue-300 text-xs transition">
                        Copier URL
                    </button>
                    <form method="post" action="{{ path('app_media_delete', {'id': media.id}) }}"
                          onsubmit="return confirm('Supprimer cette image ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ media.id) }}">
                        <button type="submit" class="text-red-400 hover:text-red-300 text-xs transition">
                            Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-span-4 text-center text-gray-600 py-12">Aucune image uploadée.</div>
        {% endfor %}
    </div>

</div>

<script>
function copyUrl(url) {
    navigator.clipboard.writeText(url).then(() => {
        alert('URL copiée : ' + url);
    });
}
</script>
{% endblock %}