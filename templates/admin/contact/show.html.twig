{% extends 'base.html.twig' %}

{% block title %}Message de {{ contact.name }}{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-6 py-16">

    <div class="flex justify-between items-center mb-10">
        <div>
            <p class="text-blue-400 text-sm uppercase tracking-widest mb-1">Administration</p>
            <h1 class="text-4xl font-bold text-white">Message reçu</h1>
        </div>
        <a href="{{ path('app_contact_admin_index') }}"
           class="border border-gray-700 hover:border-gray-500 text-gray-400 hover:text-white px-4 py-2 rounded-lg text-sm transition">
            ← Retour
        </a>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-xl p-8 space-y-6">

        <div class="grid grid-cols-3 gap-4 border-b border-gray-800 pb-6">
            <div>
                <p class="text-gray-500 text-xs uppercase tracking-widest mb-1">Nom</p>
                <p class="text-white font-medium">{{ contact.name }}</p>
            </div>
            <div>
                <p class="text-gray-500 text-xs uppercase tracking-widest mb-1">Email</p>
                <a href="mailto:{{ contact.email }}" class="text-blue-400 hover:text-blue-300 transition">{{ contact.email }}</a>
            </div>
            <div>
                <p class="text-gray-500 text-xs uppercase tracking-widest mb-1">Date</p>
                <p class="text-gray-400">{{ contact.sentAt ? contact.sentAt|date('d/m/Y à H:i') : '' }}</p>
            </div>
        </div>

        <div>
            <p class="text-gray-500 text-xs uppercase tracking-widest mb-3">Message</p>
            <p class="text-gray-300 leading-relaxed whitespace-pre-line">{{ contact.message }}</p>
        </div>

        <div class="flex justify-between items-center pt-4 border-t border-gray-800">
            <a href="mailto:{{ contact.email }}"
               class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2 rounded-lg text-sm transition">
                Répondre par email
            </a>
            {{ include('admin/contact/_delete_form.html.twig') }}
        </div>

    </div>

</div>
{% endblock %}