{% extends 'base.html.twig' %}

{% block title %}Projets{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-6 py-16">

    <h1 class="text-4xl font-bold text-white mb-2">Projets</h1>
    <p class="text-blue-400 mb-12 tracking-widest uppercase text-sm">Réalisations</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden hover:border-blue-500 transition">
            <div class="h-48 bg-gray-800 flex items-center justify-center">
                <span class="text-gray-600 text-sm">Aperçu du projet</span>
            </div>
            <div class="p-5">
                <h2 class="text-white font-medium mb-2">Nom du projet</h2>
                <p class="text-gray-400 text-sm mb-4">Description courte du projet, technologies utilisées.</p>
                <div class="flex gap-2">
                    <span class="text-xs bg-blue-900 text-blue-300 px-2 py-1 rounded">Symfony</span>
                    <span class="text-xs bg-blue-900 text-blue-300 px-2 py-1 rounded">Tailwind</span>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}