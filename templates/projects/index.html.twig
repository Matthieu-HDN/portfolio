{% extends 'base.html.twig' %}

{% block title %}Projets{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-6 py-16">

    <h1 class="text-4xl font-bold text-white mb-2">Projets</h1>
    <p class="text-blue-400 mb-12 tracking-widest uppercase text-sm">Réalisations</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

        {% for project in projects %}
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden hover:border-blue-500 transition">
            <div class="h-48 overflow-hidden">
                <img src="{{ project.imageUrl ?? 'https://via.placeholder.com/800x480' }}" 
                     alt="{{ project.title }}"
                     class="w-full h-full object-cover">
            </div>
            <div class="p-5">
                <h2 class="text-white font-medium mb-2">{{ project.title }}</h2>
                <p class="text-gray-400 text-sm mb-4">{{ project.description }}</p>
                <div class="flex flex-wrap gap-2">
                    {% for tag in project.tags|split(',') %}
                    <span class="text-xs bg-blue-900 text-blue-300 px-2 py-1 rounded">{{ tag|trim }}</span>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% else %}
        <p class="text-gray-500">Aucun projet pour le moment.</p>
        {% endfor %}

    </div>
</div>
{% endblock %}