{% extends 'base.html.twig' %}

{% block title %}{{ project.title }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-6 py-16">

    <a href="{{ path('app_projects') }}" class="text-blue-400 hover:text-blue-300 text-sm transition mb-8 inline-block">
        ← Retour aux projets
    </a>

    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">

        <div class="h-64 overflow-hidden">
            <img src="{{ project.imageUrl ?? 'https://picsum.photos/800/480' }}"
                 alt="{{ project.title }}"
                 class="w-full h-full object-cover">
        </div>

        <div class="p-8">
            <h1 class="text-3xl font-bold text-white mb-4">{{ project.title }}</h1>

            <div class="flex flex-wrap gap-2 mb-6">
                {% for tag in project.tags|split(',') %}
                <span class="text-xs bg-blue-900 text-blue-300 px-2 py-1 rounded">{{ tag|trim }}</span>
                {% endfor %}
            </div>

            <p class="text-gray-300 leading-relaxed mb-8">{{ project.description }}</p>

            {% if project.projectUrl %}
            <a href="{{ project.projectUrl }}" target="_blank"
               class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-3 rounded-lg transition inline-block">
                Voir le projet
            </a>
            {% endif %}
        </div>

    </div>

</div>
{% endblock %}