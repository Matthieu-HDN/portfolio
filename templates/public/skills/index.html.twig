{% extends 'base.html.twig' %}

{% block title %}Compétences{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-6 py-16">

    <h1 class="text-4xl font-bold text-white mb-2">Compétences</h1>
    <p class="text-blue-400 mb-12 tracking-widest uppercase text-sm">Stack technique</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <h2 class="text-blue-400 font-medium mb-4 uppercase text-sm tracking-widest">Développement</h2>
            <ul class="space-y-2 text-gray-300">
                <li>PHP / Symfony</li>
                <li>HTML / CSS</li>
                <li>JavaScript ES6+</li>
                <li>Tailwind CSS</li>
                <li>MySQL / Doctrine</li>
                <li>Git / GitHub</li>
            </ul>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <h2 class="text-blue-400 font-medium mb-4 uppercase text-sm tracking-widest">Infographie</h2>
            <ul class="space-y-2 text-gray-300">
                <li>Adobe Photoshop</li>
                <li>Adobe Illustrator</li>
                <li>Adobe InDesign</li>
                <li>UI / Mise en page</li>
                <li>Identité visuelle</li>
            </ul>
        </div>

    </div>
</div>
{% endblock %}