{% extends 'base.html.twig' %}

{% block title %}Compétences{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-6 py-16">

    <h1 class="text-4xl font-bold text-white mb-2">Compétences</h1>
    <p class="text-blue-400 mb-12 tracking-widest uppercase text-sm">Stack technique</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        {% for category, skills in skillsByCategory %}
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <h2 class="text-blue-400 font-medium mb-6 uppercase text-sm tracking-widest">{{ category }}</h2>
            <div class="space-y-4">
                {% for skill in skills %}
                <div>
                    <div class="flex justify-between text-sm mb-1">
                        <span class="text-gray-300">{{ skill.name }}</span>
                        <span class="text-gray-500">{{ skill.level }}%</span>
                    </div>
                    <div class="w-full bg-gray-800 rounded-full h-1.5">
                        <div class="bg-blue-500 h-1.5 rounded-full transition-all"
                             style="width: {{ skill.level }}%"></div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}

    </div>
</div>
{% endblock %}