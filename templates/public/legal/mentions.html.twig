{% extends 'base.html.twig' %}

{% block title %}Mentions légales{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-12 items-start">

    <div class="md:col-span-2">
        <h1 class="text-4xl font-bold text-white mb-2">Mentions légales</h1>
        <p class="text-blue-400 mb-12 tracking-widest uppercase text-sm">Informations légales</p>

        <div class="space-y-8 text-gray-400 leading-relaxed">
            <div>
                <h2 class="text-white font-medium text-lg mb-3">Éditeur du site</h2>
                <p>Matthieu [Nom]</p>
                <p>Adresse : [Votre adresse]</p>
                <p>Email : [votre@email.com]</p>
            </div>
            <div>
                <h2 class="text-white font-medium text-lg mb-3">Hébergement</h2>
                <p>Ce site est hébergé par Railway</p>
                <p>railway.app</p>
            </div>
            <div>
                <h2 class="text-white font-medium text-lg mb-3">Propriété intellectuelle</h2>
                <p>L'ensemble du contenu de ce site est la propriété exclusive de Matthieu [Nom], sauf mention contraire.</p>
            </div>
        </div>
    </div>

    <div class="hidden md:flex items-center justify-center h-full">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="w-48 h-48 opacity-20">
            <circle cx="50" cy="50" r="40" fill="none" stroke="#60a5fa" stroke-width="1"/>
            <circle cx="50" cy="50" r="30" fill="none" stroke="#60a5fa" stroke-width="0.5"/>
            <circle cx="50" cy="50" r="20" fill="none" stroke="#60a5fa" stroke-width="0.5"/>
            <line x1="10" y1="50" x2="90" y2="50" stroke="#60a5fa" stroke-width="0.5"/>
            <line x1="50" y1="10" x2="50" y2="90" stroke="#60a5fa" stroke-width="0.5"/>
            <circle cx="50" cy="50" r="3" fill="#60a5fa"/>
        </svg>
    </div>

</div>
{% endblock %}