{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}

<section class="relative flex flex-col justify-center min-h-screen w-full overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center"
         style="background-image: url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1400');">
    </div>
    <div class="absolute inset-0 bg-gray-950/75"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-10 py-16 w-full">
        <p class="text-blue-400 text-sm font-medium mb-3 tracking-widest uppercase">Bonjour, je suis</p>
        <h1 class="text-5xl font-bold text-white mb-4">Matthieu</h1>
        <h2 class="text-2xl text-blue-300 mb-6">Infographiste & Développeur Web</h2>
        <p class="text-gray-300 max-w-xl leading-relaxed mb-8">
            Créatif et technique, je conçois des interfaces soignées et développe des applications web robustes.
        </p>
        <div class="flex gap-4">
            <a href="{{ path('app_projects') }}" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-3 rounded-lg transition">
                Voir mes projets
            </a>
            <a href="{{ path('app_contact') }}" class="border border-blue-500 hover:border-blue-300 text-blue-300 px-6 py-3 rounded-lg transition">
                Me contacter
            </a>
        </div>
    </div>
</section>
<section class="max-w-5xl mx-auto px-6 py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

        <div>
            <p class="text-blue-400 text-sm font-medium mb-3 tracking-widest uppercase">À propos</p>
            <h2 class="text-3xl font-bold text-white mb-6">Créatif et technique</h2>
            <p class="text-gray-400 leading-relaxed mb-4">
                Fort de plus de 15 ans d'expérience en infographie et développement web, 
                je conçois des interfaces soignées et développe des applications robustes.
            </p>
            <p class="text-gray-400 leading-relaxed mb-8">
                Passionné de science-fiction et de design d'interface, j'apporte une vision 
                créative à chaque projet technique.
            </p>
            <div class="flex gap-4">
                <a href="{{ path('app_skills') }}" 
                   class="border border-blue-500 hover:border-blue-300 text-blue-400 hover:text-blue-300 px-5 py-2 rounded-lg transition text-sm">
                    Mes compétences
                </a>
                <a href="{{ path('app_contact') }}"
                   class="border border-gray-600 hover:border-gray-400 text-gray-400 hover:text-gray-300 px-5 py-2 rounded-lg transition text-sm">
                    Me contacter
                </a>
            </div>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-xl p-8">
            <div class="space-y-4">
                <div class="flex items-center gap-4">
                    <span class="text-blue-400 text-2xl">✦</span>
                    <div>
                        <p class="text-white font-medium">+15 ans d'expérience</p>
                        <p class="text-gray-500 text-sm">Infographie & développement web</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-blue-400 text-2xl">✦</span>
                    <div>
                        <p class="text-white font-medium">Double compétence</p>
                        <p class="text-gray-500 text-sm">Créatif et technique</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-blue-400 text-2xl">✦</span>
                    <div>
                        <p class="text-white font-medium">Stack moderne</p>
                        <p class="text-gray-500 text-sm">Symfony, Tailwind, Git</p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
{% endblock %}