{% extends 'base.html.twig' %}

{% block title %}Contact{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-12 items-start">

    <div class="md:col-span-2">
        <h1 class="text-4xl font-bold text-white mb-2">Contact</h1>
        <p class="text-blue-400 mb-12 tracking-widest uppercase text-sm">Travaillons ensemble</p>

        {% for message in app.flashes('success') %}
        <div class="bg-blue-900 border border-blue-500 text-blue-300 rounded-lg px-4 py-3 mb-6">
            {{ message }}
        </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
        <div class="bg-red-900 border border-red-500 text-red-300 rounded-lg px-4 py-3 mb-6">
            {{ message }}
        </div>
        {% endfor %}

        {{ form_start(form) }}
        <div class="space-y-6">
            <div>
                {{ form_label(form.name, 'Nom', {'label_attr': {'class': 'block text-gray-400 text-sm mb-2'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition'}}) }}
            </div>
            <div>
                {{ form_label(form.email, 'Email', {'label_attr': {'class': 'block text-gray-400 text-sm mb-2'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition'}}) }}
            </div>
            <div>
                {{ form_label(form.message, 'Message', {'label_attr': {'class': 'block text-gray-400 text-sm mb-2'}}) }}
                {{ form_widget(form.message, {'attr': {'class': 'w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition', 'rows': 6}}) }}
            </div>
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white py-3 rounded-lg transition font-medium">
                Envoyer
            </button>
        </div>
        {{ form_end(form) }}
    </div>

    <div class="hidden md:flex items-center justify-center h-full">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="w-48 h-48 opacity-20">
            <circle cx="50" cy="50" r="40" fill="none" stroke="#60a5fa" stroke-width="1"/>
            <circle cx="50" cy="50" r="30" fill="none" stroke="#60a5fa" stroke-width="0.5"/>
            <circle cx="50" cy="50" r="20" fill="none" stroke="#60a5fa" stroke-width="0.5"/>
            <line x1="10" y1="50" x2="90" y2="50" stroke="#60a5fa" stroke-width="0.5"/>
            <line x1="50" y1="10" x2="50" y2="90" stroke="#60a5fa" stroke-width="0.5"/>
            <circle cx="50" cy="50" r="3" fill="#60a5fa"/>
        </svg>
    </div>

</div>
{% endblock %}